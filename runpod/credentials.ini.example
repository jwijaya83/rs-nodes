# RunPod credentials for the rs-nodes dispatcher.
#
# Copy this file to:
#   Windows: %USERPROFILE%\.runpod\credentials.ini
#   POSIX:   ~/.runpod/credentials.ini
#
# Then fill in your real api_key + user_id values from
# https://www.runpod.io/console/user/settings .
#
# The dispatcher node has a `profile` widget that selects which section
# is used. Default value is "default". RUNPOD_PROFILE env var can also
# select a section. If no file exists, RUNPOD_API_KEY + RUNPOD_USER_ID
# env vars work as a single-account fallback.

[default]
api_key = rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
user_id = user_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
label   = work

[personal]
api_key = rpa_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
user_id = user_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
label   = personal
